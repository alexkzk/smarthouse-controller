# Copy to .env and fill in your values before running docker-compose

# PostgreSQL
SMARTHOUSE_DB_USERNAME=smarthouse
SMARTHOUSE_DB_PASSWORD=changeme
POSTGRES_DATA_PATH=./postgresql_data

# InfluxDB
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=changeme
INFLUXDB_ORG=Home
INFLUXDB_TOKEN=your-influxdb-token-here
INFLUXDB_DATA_PATH=./influxdb_data

# Git / SSH (for docker-entrypoint.sh auto-build)
GIT_REPO_SSH=git@github.com:your-user/smarthouse-controller.git
GIT_BRANCH=master
SSH_KEY_HOST_PATH=~/.ssh/id_rsa

# External API keys
AVWX_TOKEN=your-avwx-token-here
# weatherapi.key — set in application.yml or pass as SPRING_APPLICATION_JSON

# Airplanes.live (set your monitoring area coordinates)
# airplanes.live.baseUrl=https://api.airplanes.live/v2/point/<lat>/<lon>/15

# MQTT broker host (for local/remote profiles)
MQTT_HOST=localhost

# Database host (for remote profile)
SMARTHOUSE_DB_HOST=localhost
